# Supabase — pegue em: Project Settings → Data API / API Keys
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# URL pública do site (usada pelos apps Android/iOS nos links de e-mail de
# confirmação/recuperação — dentro do app a origem é localhost e não serve).
# Obrigatória ao buildar para mobile (npm run mobile:sync).
VITE_SITE_URL=https://seu-dominio.com.br

# ─────────────────────────────────────────────────────────────
# Secrets das Edge Functions (NÃO vão no frontend / build do Vite).
# Configure com: supabase secrets set NOME=valor
#
#   STRIPE_SECRET_KEY          chave secreta do Stripe
#   STRIPE_WEBHOOK_SECRET      signing secret do webhook
#   STRIPE_PRICE_ID            price Solo MENSAL  (R$27/mês)
#   STRIPE_PRICE_ID_ANNUAL     price Solo ANUAL   (R$238,80/ano)
#   STRIPE_PRICE_ID_DUO        price Duo  MENSAL  (R$44,90/mês)
#   STRIPE_PRICE_ID_DUO_ANNUAL price Duo  ANUAL   (R$478,80/ano)
#
#   OPENAI_API_KEY             chave secreta da OpenAI (assistente de IA)
#   OPENAI_MODEL               modelo opcional (padrão: gpt-4o-mini)
# ─────────────────────────────────────────────────────────────
